{
  "name": "suited",
  "version": "1.0.0",
  "description": "CLI tool to generate tailored, factually-accurate resumes from LinkedIn data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "suited": "./dist/index.js"
  },
  "engines": {
    "node": ">=20.12"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prepare": "pnpm build",
    "build": "tsc && rm -rf dist/templates && cp -r src/templates dist/templates",
    "build:bundle": "node scripts/build-binary.mjs",
    "build:binary": "node scripts/build-binary.mjs && node scripts/package-sea.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "adm-zip": "^0.5.16",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "eta": "^3.5.0",
    "figlet": "^1.11.0",
    "inquirer": "^12.4.2",
    "openai": "^6.29.0",
    "puppeteer-core": "^23.11.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
